#!/usr/bin/env bash

set -euo pipefail

usage() {
	echo "Usage: $0 VM_NAME -L LOCAL_PORT:HOST:REMOTE_PORT... [-f]" >&2
	echo >&2
	echo "  -L SPEC  Add a local port forward using the same format as ssh -L" >&2
	echo "  -f       Run ssh in the background" >&2
}

if [[ $# -eq 0 ]]; then
	usage
	exit 1
fi

VM_NAME=""
BACKGROUND=0
PORT_FORWARDS=()

while [[ $# -gt 0 ]]; do
	case "$1" in
		-h|--help)
			usage
			exit 0
			;;
		-f)
			BACKGROUND=1
			shift
			;;
		-L)
			if [[ $# -lt 2 || -z "$2" ]]; then
				echo "Missing value for -L" >&2
				usage
				exit 1
			fi
			PORT_FORWARDS+=("$2")
			shift 2
			;;
		-*)
			echo "Unknown option: $1" >&2
			usage
			exit 1
			;;
		*)
			if [[ -n "$VM_NAME" ]]; then
				echo "Unexpected argument: $1" >&2
				usage
				exit 1
			fi
			VM_NAME="$1"
			shift
			;;
	esac
	done

if [[ -z "$VM_NAME" ]]; then
	usage
	exit 1
fi

if [[ ${#PORT_FORWARDS[@]} -eq 0 ]]; then
	echo "At least one -L port forward is required" >&2
	usage
	exit 1
fi

VM_USER="$(macadam inspect "$VM_NAME" | jq -r '.[0].SSHConfig.RemoteUsername')"
SSH_PORT="$(macadam inspect "$VM_NAME" | jq -r '.[0].SSHConfig.Port')"
SSH_KEY="$(macadam inspect "$VM_NAME" | jq -r '.[0].SSHConfig.IdentityPath')"

SSH_ARGS=("-i" "$SSH_KEY" "-p" "$SSH_PORT" "-N")

if [[ $BACKGROUND -eq 1 ]]; then
	SSH_ARGS+=("-f")
fi

for port_forward in "${PORT_FORWARDS[@]}"; do
	SSH_ARGS+=("-L" "$port_forward")
done

SSH_ARGS+=("$VM_USER"@127.0.0.1)

ssh "${SSH_ARGS[@]}"